/* ================ IF GUARD COUNTER CLOCKWISE DIRECTION TO BOND LESS THAN ================ */

#define CMDNAME IF_GUARD_COUNTER_CLOCKWISE_DIRECTION_TO_BOND_LESS_THAN
//#define CMDNAME IfGuardCounterClockwiseDirectionToBondLessThan
// Alternative Names?
// aiIfTargetInFovLeft or aiIfBondOutOfFov

#define DESCRIPTION \
/*******************************************************************************
* If guard's counter-clockwise direction to Bond < DIRECTION, Goto LABEL       *
* @param Direction input (Degrees):                                            *
*                00: No rotation, never Goto LABEL because degrees are always  *
*                    above 0                                                   *
*                90: Bond must be within Guard's 9-to-12 o'clock               *
*               180: Bond must be on Guard's left-side 6-to-12 o'clock         *
*               270: Bond must be within Guard's 3-to-12 o'clock               *
*               360: Always Goto LABEL - Bond is Always < DIRECTION            *
*******************************************************************************/

#define PARAMS DEG(DIRECTION), BYTE(GOTOLABEL)

_AI_CMD(
    {
        AIRecord *ai  = AiListp + Offset;
        float     rad = chrGetAngleToBond(ChrEntityp);
        if (ByteToRadian((ai->val[0])) > rad)
        {
            Offset = chraiGoToLabel(AiListp, Offset, ai->val[1]);
        }
        else
        {
            Offset += CAT(CAT(AI_, CMDNAME), _LENGTH);
        }
        break;
    })
_AI_CMD_POLYMORPH(CMDNAME,
                  IF_GUARD_COUNTER_CLOCKWISE_DIRECTION_TO_BOND_LESS_THAN_RAD,
                  (RAD2BYTE(DIRECTION), GOTOLABEL),
                  (DIRECTION, GOTOLABEL),
                  DESCRIPTION)
#undef PARAMS
#undef CMDNAME
#undef DESCRIPTION
#undef CODE




/* ================ IF GUARD COUNTER CLOCKWISE DIRECTION TO BOND GREATER THAN ================ */

#define CMDNAME IF_GUARD_COUNTER_CLOCKWISE_DIRECTION_TO_BOND_GREATER_THAN
//#define CMDNAME IfGuardCounterClockwiseDirectionToBondGreaterThan

#define DESCRIPTION \
/*******************************************************************************
* If guard's counter-clockwise direction to Bond > DIRECTION, Goto LABEL       *
* @param Direction input (Degrees):                                            *
*                00: No rotation, always Goto LABEL because degrees are always *
*                    above 0                                                   *
*                90: Bond must be within Guard's 12-to-9 o'clock               *
*               180: Bond must be on Guard's right-side 12-to-6 o'clock        *
*               270: Bond must be within Guard's 12-to-3 o'clock               *
*               360: Never Goto LABEL - Bond is Always < DIRECTION             *
*******************************************************************************/

#define PARAMS DEG(DIRECTION), BYTE(GOTOLABEL)

_AI_CMD(
    {
        AIRecord *ai  = AiListp + Offset;
        float     rad = chrGetAngleToBond(ChrEntityp);
        if (ByteToRadian((ai->val[0])) < rad)
        {
            Offset = chraiGoToLabel(AiListp, Offset, ai->val[1]);
        }
        else
        {
            Offset += CAT(CAT(AI_, CMDNAME), _LENGTH);
        }
        break;
    })
#undef PARAMS
#undef CMDNAME
#undef DESCRIPTION
#undef CODE




