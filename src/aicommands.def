/* ================ CAMERA ORBIT PAD ================ */

#define CMDNAME CAMERA_ORBIT_PAD
//#define CMDNAME CameraOrbitPad

#define DESCRIPTION \
/*******************************************************************************
* Change view to orbit a pad with set speed                                    *
* @param LAT_DISTANCE unsigned camera distance from pad,                       *
*               100 units per meter.                                           *
*             VERT_DISTANCE signed camera distance from pad,                   *
*               100 units per meter.                                           *
*             ORBIT_SPEED signed speed to orbit around pad. Unit format uses   *
*               compass direction like target commands:                        *
*                   GUARD_TRY_FIRE_OR_AIM_AT_TARGET,                           *
*                   GUARD_TRY_FIRE_OR_AIM_AT_TARGET_KNEEL,                     *
*                   GUARD_TRY_FIRE_OR_AIM_AT_TARGET_UPDATE,                    *
*                   GUARD_TRY_FACING_TARGET.                                   *
*                   Generally stick to a low range as it is used for delta     *
*               timing (0100-FF00)                                             *
*             PAD pad for camera to target and orbit around                    *
*             Y_POS_OFFSET signed offset the relative y position for pad       *
*               (boom/jib)                                                     *
*             INITIAL_ROTATION uses compass direction like target commands     *
*               but inverted -                                                 *
*               hex N: 0000 E: C000 S: 8000: W: 4000                           *
********************************************************************************
* Notes: Must have a BOND_HIDE_WEAPONS and 3 SLEEP commands before executing   *
*       or else engine will crash on console (use CAMERA_TRANSITION_FROM_BOND).*
*       If camera mode is already in third person then you do NOT need to do   *
*       the above.                                                             *
*       Mission time is paused while in third person                           *
*******************************************************************************/

#define PARAMS DBYTE(LAT_DISTANCE), DBYTE(VERT_DISTANCE), DBYTE(ORBIT_SPEED60), DBYTE(PAD), DBYTE(Y_POS_OFFSET), DBYTE(INITIAL_ROTATION)

_AI_CMD(
    {
        AIRecord * ai = AiListp + Offset;
        s32       padnum;
        s32       a;
        s32       b;
        s32       c;
        s32       height;
        s32       speed;
        b = ai->val[1] | ai->val[0] << 8;
        height = (s16) (ai->val[3] | ai->val[2] << 8);
        a = (s16) (ai->val[5] | ai->val[4] << 8);
        padnum = ai->val[7] | ai->val[6] << 8;
        c = (s16) (ai->val[9] | ai->val[8] << 8);
        speed = ai->val[11] | ai->val[10] << 8;
        dword_CODE_bss_800799F8 = NULL;
        gBondViewCutscene = NULL;
        flt_CODE_bss_80079A00   = (speed * M_TAU_F) / M_U16_MAX_VALUE_F; 
        flt_CODE_bss_80079A04   = (a * M_TAU_F) / M_U16_MAX_VALUE_F;
        flt_CODE_bss_80079A08 = b;
        flt_CODE_bss_80079A0C = height; 
        flt_CODE_bss_80079A10 = c;
        dword_CODE_bss_80079A14 = padnum;   
        set_camera_mode(CAMERAMODE_POSEND); 
        Offset += CAT(CAT(AI_, CMDNAME), _LENGTH)3;
        break;
    }
)
#undef PARAMS
#undef CMDNAME
#undef DESCRIPTION
#undef CODE




