/* ================ GUARD TRY FIRE OR AIM AT TARGET ================ */

#define CMDNAME GUARD_TRY_FIRE_OR_AIM_AT_TARGET
//#define CMDNAME GuardTryFireOrAimAtTarget

#define DESCRIPTION \
/*******************************************************************************
* Make guard aim/fire their weapon at TARGET,                                  *
* Goto LABEL if successful                                                     *
* @param TARGET 16bit ID                                                       *
*             (BITFIELD 16bit Target Type)                                     *
********************************************************************************
* Notes: Use TARGET_# flags to set the target type (pad/Bond/chr) or use       *
*       Seperated commands eg GUARD_TRY_FIRE_AT_PAD                            *
*******************************************************************************/

#define PARAMS DBYTE(BITFIELD), DBYTE(TARGET), BYTE(GOTOLABEL)

_AI_CMD(
    {
        AIRecord *ai         = AiListp + Offset;
        s32       targetid   = ai->val[3] | (ai->val[2] << 8);
        s32       targettype = ai->val[1] | (ai->val[0] << 8);
        if (actor_aim_at_actor(ChrEntityp, targettype, targetid))
        {
            Offset = chraiGoToLabel(AiListp, Offset, ai->val[4]);
        }
        else
        {
            Offset += CAT(CAT(AI_, CMDNAME), _LENGTH);
        }
        break;
    })

//POLYMORPHS
#undef DESCRIPTION
#define DESCRIPTION \
/*******************************************************************************
* Make guard aim/fire their weapon at TARGET,                                  *
* Goto LABEL if successful                                                     *
* @param TARGET 16bit ID                                                       *
*******************************************************************************/

_AI_CMD_POLYMORPH(CMDNAME,
                  GUARD_TRY_FIRE_AT_PAD,
                  (TARGET_PAD, TARGET, GOTOLABEL),
                  (TARGET, GOTOLABEL),
                  DESCRIPTION)
_AI_CMD_POLYMORPH(CMDNAME,
                  GUARD_TRY_AIM_AT_PAD,
                  (TARGET_PAD | TARGET_AIM_ONLY, TARGET, GOTOLABEL),
                  (TARGET, GOTOLABEL),
                  DESCRIPTION)
_AI_CMD_POLYMORPH(CMDNAME,
                  GUARD_TRY_FIRE_AT_BOND,
                  (TARGET_BOND, 0, GOTOLABEL),
                  (GOTOLABEL),
                  DESCRIPTION)
_AI_CMD_POLYMORPH(CMDNAME,
                  GUARD_TRY_AIM_AT_BOND,
                  (TARGET_BOND | TARGET_AIM_ONLY, 0, GOTOLABEL),
                  (GOTOLABEL),
                  DESCRIPTION)

#undef PARAMS
#undef CMDNAME
#undef DESCRIPTION
#undef CODE




