/* ================ IF CHR DISTANCE TO PAD LESS THAN ================ */

#define CMDNAME IF_CHR_DISTANCE_TO_PAD_LESS_THAN
//#define CMDNAME IfChrDistanceToPadLessThan

#define DESCRIPTION \
/*******************************************************************************
* If chrs distance to PAD < DISTANCE, Goto LABEL                               *
********************************************************************************/

#define PARAMS BYTE(CHR_NUM), DBYTE(DISTANCE), DBYTE(PAD), BYTE(GOTOLABEL)
#define DESCRIPTION2 \
/********************************************************************************
* Notes: Argument scale is 10 units per meter                                  *
*******************************************************************************/

_AI_CMD(
    {
        AIRecord * ai     = AiListp + Offset;
        ChrRecord *chr    = chrFindById(ChrEntityp, ai->val[0]);
        u16        padnum = (ai->val[4] | (ai->val[3] << 8));
        f32        value  = (ai->val[2] | (ai->val[1] << 8)) * 10.0f;
        if (chr && (value > chrGetDistanceToPad(chr, padnum)))
        {
            Offset = chraiGoToLabel(AiListp, Offset, ai->val[5]);
        }
        else
        {
            Offset += CAT(CAT(AI_, CMDNAME), _LENGTH);
        }
        break;
    })

_AI_CMD_POLYMORPH(CMDNAME,
                    IF_CHR_METERS_TO_PAD_LESS_THAN,
                    (CHR_NUM, (DISTANCE * 10), PAD, GOTOLABEL),
                    (CHR_NUM, DISTANCE, PAD, GOTOLABEL),
                    DESCRIPTION)
_AI_CMD_POLYMORPH(CMDNAME,
                    IF_SELF_METERS_TO_PAD_LESS_THAN,
                    (CHR_SELF, (DISTANCE * 10), PAD, GOTOLABEL),
                    (DISTANCE, PAD, GOTOLABEL),
                    DESCRIPTION)
_AI_CMD_POLYMORPH(CMDNAME,
                    IF_SELF_DISTANCE_TO_PAD_LESS_THAN,
                    (CHR_SELF, (DISTANCE * 10), PAD, GOTOLABEL),
                    (DISTANCE, PAD, GOTOLABEL),
