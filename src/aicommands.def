            s8 slotID;
            u8 val[];
        } *ai = AiListp + Offset;
        f32 vol = ai->val[1] | (ai->val[0] << 8);
        u16 sfxID = ai->val[3] | (ai->val[2] << 8);
        if (ai->slotID >= 0 && ai->slotID < 8)
