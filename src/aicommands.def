/* ================ IF LOCAL TIMER HAS STOPPED ================ */

#define CMDNAME IF_LOCAL_TIMER_HAS_STOPPED
//#define CMDNAME IfLocalTimerHasStopped

#define DESCRIPTION \
/*******************************************************************************
* If chr->timer60 is not active (paused), Goto LABEL                           *
********************************************************************************
* Notes: By default, chr->timer60 is inactive                                  *
*******************************************************************************/

#define PARAMS BYTE(GOTOLABEL)

_AI_CMD(
    {
        AIRecord *ai = AiListp + Offset;
        if (((ChrEntityp->hidden & CHRHIDDEN_TIMER_ACTIVE) == 0))
        {
            Offset = chraiGoToLabel(AiListp, Offset, ai->val[0]);
        }
        else
        {
            Offset += CAT(CAT(AI_, CMDNAME), _LENGTH);
        }
        break;
    })
#undef PARAMS
#undef CMDNAME
#undef DESCRIPTION
#undef CODE




/* ================ IF LOCAL TIMER LESS THAN ================ */

#define CMDNAME IF_LOCAL_TIMER_LESS_THAN
//#define CMDNAME IfLocalTimerLessThan

#define DESCRIPTION \
/*******************************************************************************
* If chr->timer60 < TIME60, Goto LABEL                                         *
* @param TIME60 Unsigned                                                       *
********************************************************************************
* Notes: TIME60 is converted to float and compared.                            *
*       Chr->timer60 only counts up                                            *
*******************************************************************************/

#define PARAMS TBYTE(TIME60), BYTE(GOTOLABEL)

_AI_CMD(
    {
        AIRecord * ai = AiListp + Offset;
        f32      valf = ((unsigned) ((ai->val[1] << 8) | ai->val[2] | (ai->val[0] << 16))) / 60.0f;

        if (chrGetTimer(ChrEntityp) < valf)
        {
            Offset = chraiGoToLabel(AiListp, Offset, ai->val[3]);
        }
        else
        {
            Offset += CAT(CAT(AI_, CMDNAME), _LENGTH);
        }
        break;
    }
)

_AI_CMD_POLYMORPH(CMDNAME,
                    IF_LOCAL_TIMER_SECONDS_LESS_THAN,
                    ((SECS_TO_TIMER60(SECONDS)), GOTOLABEL),
                    (SECONDS, GOTOLABEL),
                    DESCRIPTION)
#undef PARAMS
#undef CMDNAME
#undef DESCRIPTION
#undef CODE




