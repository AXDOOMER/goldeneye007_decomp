        f32        value = (ai->val[1]) * 0.1f;
        ChrRecord *chr   = chrFindById(ChrEntityp, ai->val[0]);

        if (chr && ((chr->maxdamage - chr->damage) > value))
        {
            Offset = chraiGoToLabel(AiListp, Offset, ai->val[2]);
        }
        else
