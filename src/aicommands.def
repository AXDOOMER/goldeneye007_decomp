/* ================ CHR HIDE ALL ================ */

#define CMDNAME CHR_HIDE_ALL
//#define CMDNAME ChrHideAll

#define DESCRIPTION \
/*******************************************************************************
* Hide all characters in level - including Bond's third person model.          *
********************************************************************************
* Notes: Hidden characters will halt their AI List execution until unhidden    *
*       Execute this before switching to exit camera or Bond will disappear    *
*******************************************************************************/

#define PARAMS

_AI_CMD(
    {
        s32 num;
        for (num = get_numguards() - 1; num >= 0; num--)
        {
            if (ptr_guard_data[num].model != NULL)
            {
                ptr_guard_data[num].chrflags |= CHRFLAG_HIDDEN;
            }
        }
        Offset += CAT(CAT(AI_, CMDNAME), _LENGTH);
        break;
    }
)
#undef PARAMS
#undef CMDNAME
#undef DESCRIPTION
#undef CODE




