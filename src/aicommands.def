* Trigger guard to sidestep,                                                   *
* Goto LABEL if successful                                                     *
********************************************************************************
* Notes: Direction is random                                                   *
*******************************************************************************/

#define PARAMS BYTE(GOTOLABEL)

_AI_CMD(
