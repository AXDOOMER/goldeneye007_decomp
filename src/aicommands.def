* If Bond's health < HEALTH, Goto LABEL                                        *
* @param HEALTH u8 where 255 equal to 100% health                              *
********************************************************************************
* Notes: Does NOT check armour.                                                *
*******************************************************************************/

#define PARAMS BYTE(HEALTH), BYTE(GOTOLABEL)

