/*******************************************************************************
* Instantly remove CHR_NUM unlike GUARD_REMOVE_FADE                            *
********************************************************************************
* Notes: Will NOT drop items                                                   *
*******************************************************************************/

#define PARAMS BYTE(CHR_NUM)

_AI_CMD(
    {
        AIRecord * ai  = AiListp + Offset;
        ChrRecord *chr = chrFindById(ChrEntityp, ai->val[0]);
        if (chr && chr->prop)
