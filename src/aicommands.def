********************************************************************************
* Notes: HEALTH is unsigned, converted to float and compares different between *
*           chr->maxdamage - chr->damage.                                      *
*       Armour is tested                                                       *
*******************************************************************************/

#define PARAMS BYTE(CHR_NUM), BYTE(HEALTH), BYTE(GOTOLABEL)

_AI_CMD(
