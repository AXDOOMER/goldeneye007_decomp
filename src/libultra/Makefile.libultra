#$(BUILD_DIR)/src/libultra/audio/env.o: LIBULTRA_OPTIMIZATION := -O3

$(BUILD_DIR)/src/libultra/audio/event.o: LIBULTRA_OPTIMIZATION := -O3
$(BUILD_DIR)/src/libultra/audio/filter.o: LIBULTRA_OPTIMIZATION := -O3
$(BUILD_DIR)/src/libultra/audio/heapalloc.o: LIBULTRA_OPTIMIZATION := -O3
$(BUILD_DIR)/src/libultra/audio/heapinit.o: LIBULTRA_OPTIMIZATION := -O3
$(BUILD_DIR)/src/libultra/audio/load.o: LIBULTRA_OPTIMIZATION := -O3
