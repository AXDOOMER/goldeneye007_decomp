$(BUILD_DIR)/src/libultra/audio/save.o: LIBULTRA_OPTIMIZATION := -O3
$(BUILD_DIR)/src/libultra/audio/seq.o: LIBULTRA_OPTIMIZATION := -O3
$(BUILD_DIR)/src/libultra/audio/seqpsetbank.o: LIBULTRA_OPTIMIZATION := -O3
